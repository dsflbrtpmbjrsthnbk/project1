@using UserManagementApp.Models
@using UserManagementApp.Services
@using Microsoft.EntityFrameworkCore
@inject UserManagementApp.Data.ApplicationDbContext DbContext
@inject IUserService UserService
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="row">
    <div class="col-12">
        <h5 class="fw-bold mb-4">@Loc["Discussion"]</h5>

        <!-- Comment list -->
        <div class="d-flex flex-column gap-3 mb-4" id="comment-list" style="max-height:500px;overflow-y:auto;">
            @foreach (var c in _comments)
            {
                <div class="d-flex gap-3 p-3 bg-light rounded-4">
                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px;height:40px;">
                        <i class="bi bi-person text-primary"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <a href="/profile/@c.UserId" class="fw-bold small text-dark text-decoration-none">@c.UserName</a>
                            <span class="text-muted" style="font-size:.75rem;">@c.Date</span>
                        </div>
                        <div class="small">@((MarkupString)Markdig.Markdown.ToHtml(c.Content))</div>
                    </div>
                </div>
            }
            @if (!_comments.Any())
            {
                <p class="text-muted text-center py-3">@Loc["NoCommentsYet"]</p>
            }
        </div>

        <!-- Post comment -->
        @if (CurrentUser != null)
        {
            <div class="p-3 bg-white border border-light shadow-sm rounded-4">
                <textarea class="form-control border-0 shadow-none mb-2" rows="2"
                          placeholder='@Loc["WriteCommentPlaceholder"]'
                          @bind="_newComment" @onkeyup="HandleKeyUp"></textarea>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">@Loc["CommentInputTip"]</span>
                    <button class="btn btn-primary btn-sm rounded-pill px-4"
                            @onclick="PostComment" disabled="@(!_isConnected || string.IsNullOrWhiteSpace(_newComment))">
                        @Loc["Post"]
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-light text-center small py-2">
                <a href="/Account/Login" class="text-decoration-none fw-bold">@Loc["Login"]</a> @Loc["JoinDiscussionMsg"].ToString().ToLower()
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid InventoryId { get; set; }
    [Parameter] public User? CurrentUser { get; set; }

    private List<CommentViewModel> _comments = new();
    private string _newComment = "";
    private HubConnection? _hubConnection;

    public bool _isConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        // Load existing comments from DB
        var dbComments = await DbContext.InventoryComments
            .Include(c => c.User)
            .Where(c => c.InventoryId == InventoryId)
            .OrderBy(c => c.CreatedAt)
            .ToListAsync();

        _comments = dbComments.Select(c => new CommentViewModel
        {
            UserId = c.UserId.ToString(),
            UserName = c.User?.Name ?? "Unknown",
            Content = c.Content,
            Date = c.CreatedAt.ToString("g")
        }).ToList();

        // Connect to SignalR
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/discussionHub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, string, string, string>("ReceiveComment", (userId, userName, content, date) =>
        {
            _comments.Add(new CommentViewModel { UserId = userId, UserName = userName, Content = content, Date = date });
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await _hubConnection.SendAsync("JoinInventory", InventoryId.ToString());
    }

    private async Task PostComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment) || _hubConnection == null || CurrentUser == null) return;

        await _hubConnection.SendAsync("SendComment",
            InventoryId.ToString(),
            CurrentUser.Id.ToString(),
            _newComment.Trim());

        _newComment = "";
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await PostComment();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null) await _hubConnection.DisposeAsync();
    }

    private class CommentViewModel
    {
        public string UserId { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Content { get; set; } = "";
        public string Date { get; set; } = "";
    }
}
