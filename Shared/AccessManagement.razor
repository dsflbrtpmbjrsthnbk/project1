@using UserManagementApp.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc
@inject IDbContextFactory<UserManagementApp.Data.ApplicationDbContext> DbFactory

<div class="row">
    <div class="col-md-7">
        <h5 class="fw-bold mb-3">@Loc["ManageAccess"]</h5>
        <p class="text-muted small mb-4">@Loc["ManageAccessHint"]</p>

        @if (Inventory.IsPublic)
        {
            <div class="alert alert-success border-0 rounded-4 p-4 shadow-sm mb-4">
                <div class="d-flex">
                    <i class="bi bi-globe fs-2 me-3"></i>
                    <div>
                        <h6 class="fw-bold mb-1">@Loc["PublicInventory"]</h6>
                        <p class="mb-0 small opacity-75">@Loc["PublicInventoryNote"]</p>
                    </div>
                </div>
            </div>
        }

        <div class="bg-light rounded-4 p-4 mb-4">
            <label class="form-label fw-bold small text-uppercase">@Loc["AddUserByQuery"]</label>
            <div class="position-relative">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0 rounded-end-pill shadow-none" 
                           placeholder='@Loc["SearchUserPlaceholder"]' 
                           @bind="_userQuery" @oninput="OnUserSearch" />
                </div>

                @if (_suggestions.Any())
                {
                    <div class="list-group position-absolute w-100 shadow-lg mt-2 rounded-4 overflow-hidden z-3" style="top: 100%;">
                        @foreach (var user in _suggestions)
                        {
                            <button class="list-group-item list-group-item-action border-0 py-3" @onclick="() => AddUser(user)">
                                <div class="fw-bold">@user.Name</div>
                                <div class="text-muted small">@user.Email</div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold">@Loc["UsersWithAccess"]</h6>
                <div class="text-muted small">@Loc["UsersCount", _accessList.Count]</div>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var access in _accessList)
                {
                    <div class="list-group-item border-0 py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                @(access.User?.Name?.FirstOrDefault() ?? '?')
                            </div>
                            <div>
                                <div class="fw-semibold">@(access.User?.Name ?? "Unknown")</div>
                                <div class="text-muted small">@(access.User?.Email ?? "")</div>
                            </div>
                        </div>
                        <button class="btn btn-sm btn-link text-danger p-0 shadow-none border-0" @onclick="() => RemoveAccess(access)">
                            <i class="bi bi-person-x fs-5"></i>
                        </button>
                    </div>
                }
                @if (!_accessList.Any())
                {
                    <div class="text-center py-5 text-muted small">@Loc["NoUsersAdded"]</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Inventory Inventory { get; set; } = null!;
    [Parameter] public EventCallback OnChange { get; set; }

    private string _userQuery = "";
    private List<User> _suggestions = new();
    private List<InventoryAccess> _accessList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        _accessList = await context.InventoryAccesses
            .Include(a => a.User)
            .Where(a => a.InventoryId == Inventory.Id)
            .ToListAsync();
    }

    private async Task OnUserSearch(ChangeEventArgs e)
    {
        _userQuery = e.Value?.ToString() ?? "";
        if (_userQuery.Length < 2)
        {
            _suggestions.Clear();
            return;
        }

        using var context = await DbFactory.CreateDbContextAsync();
        _suggestions = await context.Users
            .Where(u => (!string.IsNullOrEmpty(u.Name) && u.Name.Contains(_userQuery)) || (!string.IsNullOrEmpty(u.Email) && u.Email.Contains(_userQuery)))
            .Where(u => !_accessList.Any(a => a.UserId == u.Id))
            .Take(5)
            .ToListAsync();
    }

    private async Task AddUser(User user)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var access = new InventoryAccess { InventoryId = Inventory.Id, UserId = user.Id };
        
        context.InventoryAccesses.Add(access);
        await context.SaveChangesAsync();
        
        // Reload to get User object for UI
        var addedAccess = await context.InventoryAccesses.Include(a => a.User).FirstAsync(a => a.InventoryId == Inventory.Id && a.UserId == user.Id);
        _accessList.Add(addedAccess);

        _suggestions.Clear();
        _userQuery = "";
        
        await OnChange.InvokeAsync();
    }

    private async Task RemoveAccess(InventoryAccess access)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var toRemove = await context.InventoryAccesses.FirstOrDefaultAsync(a => a.InventoryId == access.InventoryId && a.UserId == access.UserId);
        if (toRemove != null)
        {
            context.InventoryAccesses.Remove(toRemove);
            await context.SaveChangesAsync();
        }
        
        _accessList.Remove(access);
        await OnChange.InvokeAsync();
    }
}
