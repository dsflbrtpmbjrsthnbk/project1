@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Web
@using UserManagementApp.Models
@using UserManagementApp.Services
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IUserService UserService
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc

<div class="page @(_isDarkMode ? "dark-theme" : "light-theme")">
    <header class="navbar navbar-expand-lg border-bottom px-3 bg-body">
        <a class="navbar-brand fw-bold" href="/">InventoryHub</a>
        
        <div class="ms-auto d-flex align-items-center">
            <div class="input-group me-3" style="max-width: 300px;">
                <input type="text" class="form-control form-control-sm" 
                       placeholder='@Loc["SearchPlaceholder"]' 
                       @bind="_searchQuery" @onkeyup="HandleSearch" />
                <button class="btn btn-outline-secondary btn-sm" @onclick='() => HandleSearch(new KeyboardEventArgs { Key = "Enter" })'>
                    <i class="bi bi-search"></i>
                </button>
            </div>

            <!-- Theme Switcher -->
            <button class="btn btn-link nav-link p-0 me-2" @onclick="ToggleTheme" title="Toggle theme">
                <i class="bi @(_isDarkMode ? "bi-sun-fill text-warning" : "bi-moon-stars-fill text-primary") fs-5"></i>
            </button>

            <!-- Language Switcher -->
            <button class="btn btn-link nav-link p-0 me-3 small fw-bold" @onclick="ToggleLanguage" title="Switch language">
                @(_isRussian ? "RU" : "EN")
            </button>

            @if (_currentUser != null)
            {
                <a class="btn btn-sm btn-success me-3 fw-bold" href="/inventory/create">
                    <i class="bi bi-plus-lg me-1"></i> @Loc["CreateInventory"]
                </a>

                <div class="dropdown me-3">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                        @_currentUser.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/personal">@Loc["MyInventories"]</a></li>
                        <li><a class="dropdown-item" href="/profile/@_currentUser.Id">@Loc["Profile"]</a></li>
                        @if (_currentUser.IsAdmin)
                        {
                            <li><a class="dropdown-item" href="/admin">@Loc["AdminControl"]</a></li>
                        }
                    </ul>
                </div>
                
                <a href="/Account/Logout" class="btn btn-sm btn-danger fw-bold">@Loc["Logout"]</a>
            }
            else
            {
                <a class="btn btn-sm btn-primary" href="/Account/Login">@Loc["Login"]</a>
            }
        </div>
    </header>

    <main class="container py-4">
        @Body
    </main>

    <footer class="footer mt-auto py-3 border-top text-center text-muted">
        <div class="container">
            <span>&copy; 2026 InventoryHub</span>
        </div>
    </footer>
</div>

@code {
    private string _searchQuery = "";
    private bool _isDarkMode = false;
    private bool _isRussian = false;
    private User? _currentUser;
    private string _antiForgeryToken = "";

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await UserService.GetCurrentUserAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedTheme = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "theme");
            _isDarkMode = savedTheme == "dark";

            var savedLang = await JSRuntime.InvokeAsync<string?>("eval",
                "document.cookie.split(';').find(c=>c.trim().startsWith('language='))?.split('=')[1] ?? ''");
            _isRussian = savedLang?.Contains("ru") == true;

            _antiForgeryToken = await JSRuntime.InvokeAsync<string>("eval",
                "document.querySelector('input[name=__RequestVerificationToken]')?.value ?? ''");

            StateHasChanged();
        }
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
        {
            Navigation.NavigateTo($"/search/{Uri.EscapeDataString(_searchQuery)}");
        }
    }

    private void ToggleLanguage()
    {
        var newCulture = _isRussian ? "en-US" : "ru-RU";
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.NavigateTo($"/Account/SetLanguage?culture={newCulture}&returnUrl=/{relativePath}", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", _isDarkMode ? "dark" : "light");
        StateHasChanged();
    }
}

<style>
    .dark-theme {
        background-color: #121212;
        color: #e0e0e0;
    }
    .dark-theme .bg-body { background-color: #1e1e1e !important; }
    .dark-theme .navbar  { border-color: #333 !important; }
    .dark-theme .card    { background-color: #1e1e1e; border-color: #333; }
    .dark-theme .table   { --bs-table-bg: #1e1e1e; color: #e0e0e0; }
    .dark-theme .table-light { --bs-table-bg: #2c2c2c; }
    .dark-theme .bg-light { background-color: #2c2c2c !important; }
    .dark-theme .form-control { background-color: #2c2c2c; border-color: #444; color: white; }
    .dark-theme .input-group-text { border-color: #444; color: #aaa; background: #2c2c2c; }
    .dark-theme .dropdown-menu { background: #2c2c2c; border-color: #444; }
    .dark-theme .dropdown-item { color: #e0e0e0; }
    .dark-theme .dropdown-item:hover { background: #3a3a3a; }
    .dark-theme .text-dark { color: #e0e0e0 !important; }
    .dark-theme .bg-white { background-color: #1e1e1e !important; }
    
    .navbar-brand { letter-spacing: -0.5px; }
    .footer { font-size: 0.9rem; }
</style>
