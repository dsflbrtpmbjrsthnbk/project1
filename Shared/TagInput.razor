@using UserManagementApp.Models
@using Microsoft.EntityFrameworkCore
@inject UserManagementApp.Data.ApplicationDbContext DbContext

<div class="position-relative">
    <div class="d-flex flex-wrap gap-2 mb-2 p-2 bg-light rounded-4 border focus-ring-primary">
        @foreach (var tag in Tags)
        {
            <span class="badge bg-primary rounded-pill px-3 py-2 d-flex align-items-center fw-normal">
                #@tag
                <button type="button" class="btn btn-sm btn-link p-0 ms-2 text-white border-0 shadow-none" @onclick="() => RemoveTag(tag)">
                    <i class="bi bi-x-circle-fill"></i>
                </button>
            </span>
        }
        <input type="text" class="form-control border-0 bg-transparent flex-grow-1 shadow-none py-1" 
               placeholder="Type a tag and press Enter..." 
               @bind="_tagInput" @bind:event="oninput" @onkeyup="HandleKeyUp" />
    </div>

    @if (_suggestions.Any())
    {
        <div class="list-group position-absolute w-100 shadow-lg mt-1 rounded-4 overflow-hidden z-3">
            @foreach (var tag in _suggestions)
            {
                <button type="button" class="list-group-item list-group-item-action border-0 py-2 small" @onclick="() => SelectSuggestion(tag.Name)">
                    #@tag.Name
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<string> Tags { get; set; } = new();
    [Parameter] public EventCallback<List<string>> OnTagsChanged { get; set; }

    private string _tagInput = "";
    private List<Tag> _suggestions = new();

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == ",")
        {
            var newTag = _tagInput.TrimEnd(',').Trim().ToLower();
            if (!string.IsNullOrWhiteSpace(newTag) && !Tags.Contains(newTag, StringComparer.OrdinalIgnoreCase))
            {
                Tags.Add(newTag);
                await OnTagsChanged.InvokeAsync(Tags);
            }
            _tagInput = "";
            _suggestions.Clear();
            return;
        }

        if (_tagInput.Length > 0)
        {
            _suggestions = await DbContext.Tags
                .Where(t => t.Name.ToLower().StartsWith(_tagInput.ToLower()))
                .Take(5)
                .ToListAsync();
            
            // Remove suggestions we already added
            _suggestions.RemoveAll(s => Tags.Contains(s.Name, StringComparer.OrdinalIgnoreCase));
        }
        else
        {
            _suggestions.Clear();
        }
    }

    private async Task SelectSuggestion(string tagName)
    {
        if (!string.IsNullOrWhiteSpace(tagName) && !Tags.Contains(tagName, StringComparer.OrdinalIgnoreCase))
        {
            Tags.Add(tagName.ToLower());
            await OnTagsChanged.InvokeAsync(Tags);
        }
        _tagInput = "";
        _suggestions.Clear();
    }

    private async Task RemoveTag(string tag)
    {
        Tags.Remove(tag);
        await OnTagsChanged.InvokeAsync(Tags);
    }
}
