@using UserManagementApp.Models
@using System.Text
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject IJSRuntime JS
@inject UserManagementApp.Data.ApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc


<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="btn-toolbar shadow-sm rounded-pill overflow-hidden border bg-white">
        @if (HasWriteAccess)
        {
            <button class="btn btn-light border-0 px-3" disabled="@(_selectedItems.Count != 1)" @onclick="EditSelected">
                <i class="bi bi-pencil-square text-primary me-1"></i> @Loc["Edit"]
            </button>
            <button class="btn btn-light border-0 px-3 border-start" disabled="@(!_selectedItems.Any())" @onclick="DeleteSelected">
                <i class="bi bi-trash3 text-danger me-1"></i> @Loc["Delete"]
            </button>
        }
        <button class="btn btn-light border-0 px-3 border-start" @onclick="ExportToCsv">
            <i class="bi bi-download text-success me-1"></i> @Loc["ExportCSV"]
        </button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr>
                <th style="width: 40px;" class="ps-3">
                    <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" />
                </th>
                <th>@Loc["ID"]</th>
                @foreach (var field in Inventory.FieldDefinitions.Where(f => f.IsInTableView).OrderBy(f => f.DisplayOrder))
                {
                    <th>@field.Title</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Inventory.Items)
            {
                <tr class="@(_selectedItems.Contains(item.Id) ? "table-primary" : "")">
                    <td class="ps-3">
                        <input type="checkbox" class="form-check-input" 
                                checked="@_selectedItems.Contains(item.Id)" 
                                @onchange='e => ToggleItemSelection(item.Id, e.Value)' />
                    </td>
                    <td @onclick='() => ViewItem(item.Id)' style="cursor: pointer;"><span class="badge bg-light text-dark fw-medium">@item.CustomId</span></td>
                    @foreach (var field in Inventory.FieldDefinitions.Where(f => f.IsInTableView).OrderBy(f => f.DisplayOrder))
                    {
                        <td @onclick='() => ViewItem(item.Id)' style="cursor: pointer;">@GetFieldValue(item, field)</td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>



@code {
    [Parameter] public Inventory Inventory { get; set; } = null!;
    [Parameter] public User? CurrentUser { get; set; }
    [Parameter] public bool HasWriteAccess { get; set; }
    
    private HashSet<Guid> _selectedItems = new();

    private void ToggleItemSelection(Guid id, object? isChecked)
    {
        if (isChecked is true) _selectedItems.Add(id);
        else _selectedItems.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (e.Value is true) _selectedItems = new HashSet<Guid>(Inventory.Items.Select(i => i.Id));
        else _selectedItems.Clear();
    }

    private string? GetFieldValue(Item item, FieldDefinition field)
    {
        return field.Type switch
        {
            FieldType.String => field.SlotIndex == 0 ? item.StringField0 : field.SlotIndex == 1 ? item.StringField1 : item.StringField2,
            FieldType.Numeric => field.SlotIndex == 0 ? item.NumberField0?.ToString() : field.SlotIndex == 1 ? item.NumberField1?.ToString() : item.NumberField2?.ToString(),
            FieldType.Boolean => field.SlotIndex == 0 ? item.BoolField0?.ToString() : field.SlotIndex == 1 ? item.BoolField1?.ToString() : item.BoolField2?.ToString(),
            FieldType.Multiline => field.SlotIndex == 0 ? item.TextField0 : field.SlotIndex == 1 ? item.TextField1 : item.TextField2,
            FieldType.Link => field.SlotIndex == 0 ? item.LinkField0 : field.SlotIndex == 1 ? item.LinkField1 : item.LinkField2,
            _ => ""
        };
    }

    private async Task ExportToCsv()
    {
        var csv = new StringBuilder();
        // Header
        var headers = new List<string> { Loc["ID"], Loc["Created"] };
        headers.AddRange(Inventory.FieldDefinitions.OrderBy(f => f.DisplayOrder).Select(f => f.Title));
        csv.AppendLine(string.Join(",", headers.Select(h => $"\"{h}\"")));

        // Rows
        foreach (var item in Inventory.Items)
        {
            var values = new List<string> { item.CustomId, item.CreatedAt.ToString("g") };
            foreach (var field in Inventory.FieldDefinitions.OrderBy(f => f.DisplayOrder))
            {
                values.Add(GetFieldValue(item, field) ?? "");
            }
            csv.AppendLine(string.Join(",", values.Select(v => $"\"{v.Replace("\"", "\"\"")}\"")));
        }

        var bytes = Encoding.UTF8.GetBytes(csv.ToString());
        await JS.InvokeVoidAsync("downloadFile", $"inventory_{Inventory.Id}.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private void ViewItem(Guid id) => Navigation.NavigateTo($"inventory/{Inventory.Id}/item/{id}");
    
    private void EditSelected() 
    {
        if (_selectedItems.Count == 1 && HasWriteAccess)
        {
            Navigation.NavigateTo($"inventory/{Inventory.Id}/item/{_selectedItems.First()}");
        }
    }
    
    private async Task DeleteSelected() 
    {
        if (!HasWriteAccess || !_selectedItems.Any()) return;
        
        bool confirmed = await JS.InvokeAsync<bool>("confirm", Loc["DeleteConfirmation"].Value);
        if (!confirmed) return;
        
        var toDelete = await DbContext.Items
            .Where(i => i.InventoryId == Inventory.Id && _selectedItems.Contains(i.Id))
            .ToListAsync();
            
        DbContext.Items.RemoveRange(toDelete);
        await DbContext.SaveChangesAsync();

        foreach(var item in toDelete)
        {
            Inventory.Items.Remove(item);
        }
        _selectedItems.Clear();
    }



}
