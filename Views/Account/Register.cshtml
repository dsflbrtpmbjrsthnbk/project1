@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc
@{
    ViewData["Title"] = Loc["RegisterTitle"] + " – InventoryHub";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        :root {
            --brand: #2563eb;
            --brand-hover: #1d4ed8;
            --surface: #ffffff;
            --bg: #f1f5f9;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --radius: 12px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
            color: var(--text);
        }

        .auth-wrap { width: 100%; max-width: 400px; padding: 1.5rem; }

        .brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--brand);
            margin-bottom: 1.75rem;
            letter-spacing: -.5px;
        }
        .brand i { font-size: 1.4rem; }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        .card h1 {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: .25rem;
        }
        .card .subtitle {
            color: var(--muted);
            font-size: .875rem;
            margin-bottom: 1.5rem;
        }

        .alert {
            font-size: .875rem;
            border-radius: 8px;
            padding: .6rem .9rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .alert-danger { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }

        .form-label {
            font-size: .8rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: .35rem;
            display: block;
        }
        .form-control {
            width: 100%;
            padding: .55rem .75rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: .9rem;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
            color: var(--text);
        }
        .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(37,99,235,.12);
        }
        .form-hint {
            font-size: .75rem;
            color: var(--muted);
            margin-top: .3rem;
        }

        .mb-3 { margin-bottom: 1rem; }
        .mb-4 { margin-bottom: 1.25rem; }

        .btn-primary {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            width: 100%;
            padding: .6rem 1rem;
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: .9rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }
        .btn-primary:hover { background: var(--brand-hover); }

        .footer-text {
            text-align: center;
            margin-top: 1.25rem;
            font-size: .85rem;
            color: var(--muted);
        }
        .footer-text a {
            color: var(--brand);
            text-decoration: none;
            font-weight: 600;
        }
        .footer-text a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="auth-wrap">

    <div class="brand">
        <i class="bi bi-box-seam"></i> InventoryHub
    </div>

    <div class="card">
        <h1>@Loc["CreateOne"]</h1>
        <p class="subtitle">@Loc["RegisterSubtitle"]</p>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle-fill"></i>
                @TempData["ErrorMessage"]
            </div>
        }

        <form action="/Account/Register" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label for="name" class="form-label">@Loc["FullName"]</label>
                <input type="text" class="form-control" id="name" name="name"
                       required placeholder='@Loc["FullNamePlaceholder"]' autocomplete="name">
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">@Loc["Email"]</label>
                <input type="email" class="form-control" id="email" name="email"
                       required placeholder='@Loc["EmailPlaceholder"]' autocomplete="email">
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">@Loc["Password"]</label>
                <input type="password" class="form-control" id="password" name="password"
                       required placeholder="@Loc["Password"]" autocomplete="new-password">
                <p class="form-hint">@Loc["PasswordConstraintHint"]</p>
            </div>

            <button type="submit" class="btn-primary">
                <i class="bi bi-person-plus"></i> @Loc["CreateOne"]
            </button>
        </form>
    </div>

    <div class="footer-text">
        @Loc["AlreadyHaveAccount"] <a href="/Account/Login">@Loc["LoginHere"]</a>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
