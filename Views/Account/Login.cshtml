@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc
@{
    ViewData["Title"] = Loc["Login"] + " – InventoryHub";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        :root {
            --brand: #2563eb;
            --brand-hover: #1d4ed8;
            --surface: #ffffff;
            --bg: #f1f5f9;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --radius: 12px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
            color: var(--text);
        }

        .auth-wrap { width: 100%; max-width: 400px; padding: 1.5rem; }

        .brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--brand);
            margin-bottom: 1.75rem;
            letter-spacing: -.5px;
        }
        .brand i { font-size: 1.4rem; }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        .card h1 {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: .25rem;
        }
        .card .subtitle {
            color: var(--muted);
            font-size: .875rem;
            margin-bottom: 1.5rem;
        }

        .alert {
            font-size: .875rem;
            border-radius: 8px;
            padding: .6rem .9rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .alert-danger { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }

        /* Social buttons */
        .btn-social {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            width: 100%;
            padding: .6rem 1rem;
            border-radius: 8px;
            font-size: .9rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: background .15s, border-color .15s;
            border: 1px solid var(--border);
        }
        .btn-google {
            background: #fff;
            color: #374151;
        }
        .btn-google:hover { background: #f8fafc; color: #374151; border-color: #cbd5e1; }

        .btn-github {
            background: #24292f;
            color: #fff;
            border-color: #24292f;
        }
        .btn-github:hover { background: #000; color: #fff; }

        .divider {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: var(--muted);
            font-size: .8rem;
            margin: 1.25rem 0;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .form-label {
            font-size: .8rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: .35rem;
            display: block;
        }
        .form-control {
            width: 100%;
            padding: .55rem .75rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: .9rem;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
            color: var(--text);
        }
        .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(37,99,235,.12);
        }

        .mb-3 { margin-bottom: 1rem; }
        .mb-4 { margin-bottom: 1.25rem; }

        .btn-primary {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            width: 100%;
            padding: .6rem 1rem;
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: .9rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }
        .btn-primary:hover { background: var(--brand-hover); }

        .footer-text {
            text-align: center;
            margin-top: 1.25rem;
            font-size: .85rem;
            color: var(--muted);
        }
        .footer-text a {
            color: var(--brand);
            text-decoration: none;
            font-weight: 600;
        }
        .footer-text a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="auth-wrap">

    <div class="brand">
        <i class="bi bi-box-seam"></i> InventoryHub
    </div>

    <div class="card">
        <h1>@Loc["WelcomeBack"]</h1>
        <p class="subtitle">@Loc["SignInToAccount"]</p>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle-fill"></i>
                @TempData["ErrorMessage"]
            </div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["SuccessMessage"]
            </div>
        }



        <!-- Social Login -->
        <a href="/Account/ExternalLogin?provider=Google" class="btn-social btn-google mb-3">
            <svg width="18" height="18" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.7 1.2 9.2 3.6l6.9-6.9C35.8 2.4 30.2 0 24 0 14.8 0 7 5.4 3.2 13.3l8 6.2C13.2 13.2 18.2 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.1 5.5c4.2-3.9 6.5-9.6 6.5-16.7z"/>
                <path fill="#FBBC05" d="M11.2 28.5A14.5 14.5 0 0 1 9.5 24c0-1.6.3-3.1.7-4.5l-8-6.2A23.9 23.9 0 0 0 0 24c0 3.8.9 7.4 2.5 10.6l8.7-6.1z"/>
                <path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.1-5.5c-2 1.4-4.6 2.2-8.1 2.2-5.8 0-10.8-3.9-12.6-9.2l-8.7 6.1C7 43.3 14.9 48 24 48z"/>
            </svg>
            @Loc["ContinueWithGoogle"]
        </a>

        <a href="/Account/ExternalLogin?provider=GitHub" class="btn-social btn-github">
            <i class="bi bi-github"></i>
            @Loc["ContinueWithGitHub"]
        </a>

        <div class="divider">@Loc["OrContinueWithEmail"]</div>

        <!-- Email/Password Form -->
        <form action="/Account/Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="email" class="form-label">@Loc["Email"]</label>
                <input type="email" class="form-control" id="email" name="email"
                       required placeholder="you@example.com" autocomplete="email">
            </div>
            <div class="mb-4">
                <label for="password" class="form-label">@Loc["Password"]</label>
                <input type="password" class="form-control" id="password" name="password"
                       required placeholder="@Loc["Password"]" autocomplete="current-password">
            </div>
            <button type="submit" class="btn-primary">
                <i class="bi bi-box-arrow-in-right"></i> @Loc["SignIn"]
            </button>
        </form>
    </div>

    <div class="footer-text">
        @Loc["NoAccount"] <a href="/Account/Register">@Loc["CreateOne"]</a>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
