@page "/"
@using UserManagementApp.Models
@using Microsoft.EntityFrameworkCore
@inject UserManagementApp.Data.ApplicationDbContext DbContext

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc

<PageTitle>Home - InventoryHub</PageTitle>

<h4 class="mb-4">All Inventories</h4>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">
        @_errorMessage
    </div>
}

<div class="row g-4">
    <!-- Latest Inventories -->
    <div class="col-lg-8">
        <div class="table-responsive border rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Owner</th>
                        <th>Category</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_latestInventories.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No inventories yet.</td></tr>
                    }
                    @foreach (var inv in _latestInventories)
                    {
                        <tr>
                            <td><a href="inventory/@inv.Id" class="text-decoration-none fw-semibold">@inv.Title</a></td>
                            <td><small class="text-muted">@inv.Owner?.Name</small></td>
                            <td><span class="badge bg-light text-dark border">@inv.Category?.Name</span></td>
                            <td><small class="text-muted">@inv.CreatedAt.ToShortDateString()</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title fw-bold">Most Popular</h6>
                <ul class="list-unstyled mb-0">
                    @if (!_popularInventories.Any())
                    {
                        <li class="text-muted small">Nothing yet.</li>
                    }
                    @foreach (var inv in _popularInventories)
                    {
                        <li class="d-flex justify-content-between py-1 border-bottom">
                            <a href="inventory/@inv.Id" class="text-decoration-none small">@inv.Title</a>
                            <span class="badge bg-primary rounded-pill">@inv.Items.Count</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h6 class="card-title fw-bold">Tags</h6>
                <div class="d-flex flex-wrap gap-1">
                    @if (!_tags.Any())
                    {
                        <span class="text-muted small">No tags.</span>
                    }
                    @foreach (var tag in _tags)
                    {
                        <a href="search/tag/@tag.Name" class="badge bg-secondary text-decoration-none">#@tag.Name</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Inventory> _latestInventories = new();
    private List<Inventory> _popularInventories = new();
    private List<Tag> _tags = new();
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _latestInventories = await DbContext.Inventories
                .Include(i => i.Owner)
                .Include(i => i.Category)
                .OrderByDescending(i => i.CreatedAt)
                .Take(10)
                .ToListAsync();

            _popularInventories = await DbContext.Inventories
                .Include(i => i.Items)
                .OrderByDescending(i => i.Items.Count)
                .Take(5)
                .ToListAsync();

            _tags = await DbContext.Tags.Take(20).ToListAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading data: {ex.Message}";
        }
    }
}
