@page "/admin"
@using UserManagementApp.Models
@using UserManagementApp.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<UserManagementApp.SharedResource> Loc
@inject UserManagementApp.Data.ApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject IUserService UserService

<PageTitle>@Loc["AdminPanel"] – InventoryHub</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!_isAdmin)
{
    <div class="alert alert-danger text-center py-5">
        <i class="bi bi-shield-x display-4 d-block mb-3"></i>
        <h4>@Loc["AccessDenied"]</h4>
        <p class="mb-0">@Loc["AdminAccessRequired"]</p>
        <a href="/" class="btn btn-primary mt-3">@Loc["GoHome"]</a>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h1 class="h3 mb-0 fw-bold">@Loc["UserManagement"]</h1>
                <p class="text-muted">@Loc["UserManagementHint"]</p>
            </div>
            <div class="col-auto">
                <div class="btn-toolbar shadow-sm rounded-pill overflow-hidden border">
                    <button class="btn btn-light border-0 px-3" @onclick="BlockSelected" disabled="@(!_selectedUsers.Any())">
                        <i class="bi bi-lock-fill text-warning me-1"></i> @Loc["Block"]
                    </button>
                    <button class="btn btn-light border-0 px-3 border-start" @onclick="UnblockSelected" disabled="@(!_selectedUsers.Any())">
                        <i class="bi bi-unlock-fill text-success me-1"></i> @Loc["Unblock"]
                    </button>
                    <button class="btn btn-light border-0 px-3 border-start" @onclick="DeleteSelected" disabled="@(!_selectedUsers.Any())">
                        <i class="bi bi-person-x-fill text-danger me-1"></i> @Loc["Delete"]
                    </button>
                    <button class="btn btn-light border-0 px-3 border-start" @onclick="PromoteSelected" disabled="@(!_selectedUsers.Any())">
                        <i class="bi bi-shield-plus text-primary me-1"></i> @Loc["AddAdmin"]
                    </button>
                    <button class="btn btn-light border-0 px-3 border-start" @onclick="DemoteSelected" disabled="@(!_selectedUsers.Any())">
                        <i class="bi bi-shield-minus text-secondary me-1"></i> @Loc["RemoveAdmin"]
                    </button>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 40px;" class="ps-4">
                                <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll"
                                       checked="@(_selectedUsers.Count == _users.Count && _users.Any())" />
                            </th>
                            <th>@Loc["Name"]</th>
                            <th>@Loc["Email"]</th>
                            <th>@Loc["Status"]</th>
                            <th>@Loc["Role"]</th>
                            <th>@Loc["LastLogin"]</th>
                            <th class="pe-4">@Loc["Registered"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users)
                        {
                            <tr class="@(user.IsBlocked() ? "opacity-75" : "")">
                                <td class="ps-4">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@_selectedUsers.Contains(user.Id)"
                                           @onchange='e => ToggleUserSelection(user.Id, e.Value)' />
                                </td>
                                <td>
                                    <a href="/profile/@user.Id" class="fw-semibold text-dark text-decoration-none">@user.Name</a>
                                    @if (user.Id == _currentUser?.Id)
                                    {
                                        <span class="badge bg-info ms-2 rounded-pill small">@Loc["You"]</span>
                                    }
                                </td>
                                <td><span class="text-muted">@user.Email</span></td>
                                <td>
                                    @if (user.IsBlocked())
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-2 border border-danger border-opacity-25 rounded-pill">@Loc["Blocked"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 border border-success border-opacity-25 rounded-pill">@Loc["Active"]</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge bg-primary px-2 rounded-pill"><i class="bi bi-shield-fill-check me-1"></i>@Loc["Admin"]</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@Loc["User"]</span>
                                    }
                                </td>
                                <td><small class="text-muted">@(user.LastLoginTime?.ToString("g") ?? Loc["Never"].ToString())</small></td>
                                <td class="pe-4"><small class="text-muted">@user.RegistrationTime.ToString("d")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<User> _users = new();
    private HashSet<Guid> _selectedUsers = new();
    private User? _currentUser;
    private bool _isAdmin = false;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await UserService.GetCurrentUserAsync();
        _isAdmin = _currentUser?.IsAdmin == true;
        _loading = false;

        if (_isAdmin) await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _users = await DbContext.Users.OrderByDescending(u => u.RegistrationTime).ToListAsync();
    }

    private void ToggleUserSelection(Guid id, object? isChecked)
    {
        if (isChecked is true) _selectedUsers.Add(id);
        else _selectedUsers.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (e.Value is true) _selectedUsers = new HashSet<Guid>(_users.Select(u => u.Id));
        else _selectedUsers.Clear();
    }

    private async Task BlockSelected()
    {
        var to = _users.Where(u => _selectedUsers.Contains(u.Id)).ToList();
        foreach (var u in to) u.Status = "blocked";
        await DbContext.SaveChangesAsync();
        _selectedUsers.Clear();
        await LoadUsers();
    }

    private async Task UnblockSelected()
    {
        var to = _users.Where(u => _selectedUsers.Contains(u.Id)).ToList();
        foreach (var u in to) u.Status = "active";
        await DbContext.SaveChangesAsync();
        _selectedUsers.Clear();
        await LoadUsers();
    }

    private async Task PromoteSelected()
    {
        var to = _users.Where(u => _selectedUsers.Contains(u.Id)).ToList();
        foreach (var u in to) u.IsAdmin = true;
        await DbContext.SaveChangesAsync();
        _selectedUsers.Clear();
        await LoadUsers();
    }

    private async Task DemoteSelected()
    {
        // Admin can remove their own admin access (self-demotion is allowed per requirements)
        var to = _users.Where(u => _selectedUsers.Contains(u.Id)).ToList();
        foreach (var u in to) u.IsAdmin = false;
        await DbContext.SaveChangesAsync();
        _selectedUsers.Clear();
        await LoadUsers();

        // Refresh current user cache to reflect potential self-demotion
        _currentUser = await DbContext.Users.FirstOrDefaultAsync(u => u.Id == _currentUser!.Id);
        _isAdmin = _currentUser?.IsAdmin == true;
    }

    private async Task DeleteSelected()
    {
        var to = _users.Where(u => _selectedUsers.Contains(u.Id)).ToList();
        DbContext.Users.RemoveRange(to);
        await DbContext.SaveChangesAsync();
        _selectedUsers.Clear();
        await LoadUsers();
    }
}
