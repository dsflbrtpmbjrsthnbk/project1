@page "/search/{Query}"
@using UserManagementApp.Models
@using Microsoft.EntityFrameworkCore
@inject UserManagementApp.Data.ApplicationDbContext DbContext

<PageTitle>Search Results - InventoryHub</PageTitle>

<div class="container py-4">
    <div class="mb-5">
        <h1 class="h3 fw-bold">Search results for "@Query"</h1>
        <p class="text-muted">We found @(_inventories.Count + _items.Count) matching results.</p>
    </div>

    @if (_inventories.Any())
    {
        <h4 class="fw-bold mb-4"><i class="bi bi-collection me-2"></i>Inventories</h4>
        <div class="table-responsive bg-white rounded-4 shadow-sm p-3 mb-5">
            <table class="table table-hover align-middle mb-0">
                <tbody>
                    @foreach (var inv in _inventories)
                    {
                        <tr>
                            <td class="ps-3">
                                <a href="inventory/@inv.Id" class="text-decoration-none fw-semibold text-dark">@inv.Title</a>
                                <div class="small text-muted">@inv.Description</div>
                            </td>
                            <td class="text-end pe-3 text-muted small">@inv.Owner?.Name</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_items.Any())
    {
        <h4 class="fw-bold mb-4"><i class="bi bi-box-seam me-2"></i>Items</h4>
        <div class="table-responsive bg-white rounded-4 shadow-sm p-3">
            <table class="table table-hover align-middle mb-0">
                <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td class="ps-3 text-primary fw-bold">@item.CustomId</td>
                            <td>
                                <div class="fw-medium">Part of <a href="inventory/@item.InventoryId" class="text-decoration-none">@item.Inventory?.Title</a></div>
                                <div class="small text-muted">Created by @item.CreatedBy?.Name</div>
                            </td>
                            <td class="text-end pe-3"><a href="inventory/@item.InventoryId/item/@item.Id" class="btn btn-sm btn-link">View Item</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (!_inventories.Any() && !_items.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search text-muted opacity-25" style="font-size: 5rem;"></i>
            <h3 class="mt-4 text-muted">No results found</h3>
            <p>Try adjusting your search query or filters.</p>
        </div>
    }
</div>

@code {
    [Parameter] public string Query { get; set; } = "";
    private List<Inventory> _inventories = new();
    private List<Item> _items = new();

    protected override async Task OnParametersSetAsync()
    {
        await PerformSearch();
    }

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(Query))
        {
            _inventories.Clear();
            _items.Clear();
            return;
        }

        var normalizedQuery = Query.ToLower();

        if (DbContext.Database.ProviderName == "Microsoft.EntityFrameworkCore.Sqlite")
        {
            // Simple fallback for SQLite
            _inventories = await DbContext.Inventories
                .Include(i => i.Owner)
                .Where(i => i.Title.ToLower().Contains(normalizedQuery) || (i.Description != null && i.Description.ToLower().Contains(normalizedQuery)))
                .ToListAsync();

            _items = await DbContext.Items
                .Include(i => i.Inventory)
                .Include(i => i.CreatedBy)
                .Where(i => i.CustomId.ToLower().Contains(normalizedQuery))
                .ToListAsync();
        }
        else
        {
            // PostgreSQL FTS
            var formattedQuery = string.Join(" | ", Query.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries));
            
            _inventories = await DbContext.Inventories
                .Include(i => i.Owner)
                .Where(i => i.SearchVector.Matches(Microsoft.EntityFrameworkCore.EF.Functions.ToTsQuery("english", formattedQuery)))
                .ToListAsync();

            _items = await DbContext.Items
                .Include(i => i.Inventory)
                .Include(i => i.CreatedBy)
                .Where(i => i.SearchVector.Matches(Microsoft.EntityFrameworkCore.EF.Functions.ToTsQuery("english", formattedQuery)))
                .ToListAsync();
        }
    }
}
