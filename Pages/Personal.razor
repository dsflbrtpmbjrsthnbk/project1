@page "/personal"
@using UserManagementApp.Models
@using Microsoft.EntityFrameworkCore
@inject UserManagementApp.Data.ApplicationDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>My Inventories - InventoryHub</PageTitle>

<div class="row mb-5">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 fw-bold">My Personal Page</h1>
            <p class="text-muted">Manage your inventories and those you can contribute to.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm" @onclick="CreateNewInventory">
            <i class="bi bi-plus-lg me-2"></i>Create New Inventory
        </button>
    </div>

    <!-- Table of Owned Inventories -->
    <div class="col-12 mb-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-collection-fill me-2 text-primary"></i>My Inventories</h5>
                <div class="btn-group btn-group-sm border rounded-pill overflow-hidden shadow-none">
                     <button class="btn btn-light px-3" disabled="@(!_selectedOwned.Any())" @onclick="DeleteSelectedOwned">
                         <i class="bi bi-trash3 me-1 text-danger"></i> Delete
                     </button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;" class="ps-4">
                                <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAllOwned" />
                            </th>
                            <th>Inventory Title</th>
                            <th>Category</th>
                            <th>Items Count</th>
                            <th>Visibility</th>
                            <th class="pe-4">Last Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in _ownedInventories)
                        {
                            <tr>
                                <td class="ps-4">
                                    <input type="checkbox" class="form-check-input" 
                                           checked="@_selectedOwned.Contains(inv.Id)" 
                                           @onchange='e => ToggleOwnedSelection(inv.Id, e.Value)' />
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(inv.ImageUrl))
                                        {
                                            <img src="@inv.ImageUrl" class="rounded me-3" style="width: 32px; height: 32px; object-fit: cover;" alt="">
                                        }
                                        <a href="inventory/@inv.Id" class="text-decoration-none fw-semibold text-dark">@inv.Title</a>
                                    </div>
                                </td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill">@inv.Category?.Name</span></td>
                                <td><span class="text-muted">@inv.Items.Count items</span></td>
                                <td>
                                    @if (inv.IsPublic)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 small"><i class="bi bi-globe me-1"></i>Public</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border rounded-pill px-2 small"><i class="bi bi-lock me-1"></i>Private</span>
                                    }
                                </td>
                                <td class="pe-4 text-muted small">@inv.UpdatedAt.ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Table of Shared Inventories (Write Access) -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold"><i class="bi bi-share-fill me-2 text-info"></i>Shared With Me</h5>
                <p class="small text-muted mb-0">Inventories you have write access to.</p>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Inventory Title</th>
                            <th>Owner</th>
                            <th>Category</th>
                            <th>Items</th>
                            <th class="pe-4">Access Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var access in _sharedInventories)
                        {
                            var inv = access.Inventory;
                            <tr>
                                <td class="ps-4">
                                    <a href="inventory/@inv.Id" class="text-decoration-none fw-semibold text-dark">@inv.Title</a>
                                </td>
                                <td><span class="text-muted small">@inv.Owner?.Name</span></td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill">@inv.Category?.Name</span></td>
                                <td><span class="text-muted">@inv.Items.Count</span></td>
                                <td class="pe-4"><span class="badge bg-info bg-opacity-10 text-info rounded-pill px-2 small">Write Access</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Inventory> _ownedInventories = new();
    private List<InventoryAccess> _sharedInventories = new();
    private HashSet<Guid> _selectedOwned = new();
    private Guid _currentUserId = Guid.Empty; // Should get from auth

    protected override async Task OnInitializedAsync()
    {
        // For now, using a placeholder logic for current user
        var firstUser = await DbContext.Users.FirstOrDefaultAsync();
        if (firstUser != null) _currentUserId = firstUser.Id;

        await LoadData();
    }

    private async Task LoadData()
    {
        _ownedInventories = await DbContext.Inventories
            .Include(i => i.Category)
            .Include(i => i.Items)
            .Where(i => i.OwnerId == _currentUserId)
            .OrderByDescending(i => i.UpdatedAt)
            .ToListAsync();

        _sharedInventories = await DbContext.InventoryAccesses
            .Include(ia => ia.Inventory)
                .ThenInclude(i => i.Owner)
            .Include(ia => ia.Inventory)
                .ThenInclude(i => i.Category)
            .Include(ia => ia.Inventory)
                .ThenInclude(i => i.Items)
            .Where(ia => ia.UserId == _currentUserId)
            .ToListAsync();
    }

    private void ToggleOwnedSelection(Guid id, object? isChecked)
    {
        if (isChecked is true) _selectedOwned.Add(id);
        else _selectedOwned.Remove(id);
    }

    private void ToggleSelectAllOwned(ChangeEventArgs e)
    {
        if (e.Value is true) _selectedOwned = new HashSet<Guid>(_ownedInventories.Select(i => i.Id));
        else _selectedOwned.Clear();
    }

    private void CreateNewInventory()
    {
        Navigation.NavigateTo("inventory/create");
    }

    private async Task DeleteSelectedOwned()
    {
        var toDelete = _ownedInventories.Where(i => _selectedOwned.Contains(i.Id)).ToList();
        DbContext.Inventories.RemoveRange(toDelete);
        await DbContext.SaveChangesAsync();
        _selectedOwned.Clear();
        await LoadData();
    }
}
