@page "/inventory/{InventoryId:guid}/item/create"
@page "/inventory/{InventoryId:guid}/item/{ItemId:guid}"
@using UserManagementApp.Models
@using UserManagementApp.Services
@using Microsoft.EntityFrameworkCore
@using UserManagementApp.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject IUserService UserService
@inject ICustomIdService CustomIdService
@inject ILogger<ItemEdit> _logger

<PageTitle>@(_isNew ? "New Item" : "Edit Item") – InventoryHub</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!_hasWriteAccess)
{
    <div class="alert alert-danger text-center py-5">
        <i class="bi bi-shield-x display-4 d-block mb-3"></i>
        <h4>Access Denied</h4>
        <p class="mb-0">You don't have write access to this inventory.</p>
        <a href="/inventory/@InventoryId" class="btn btn-primary mt-3">Back to Inventory</a>
    </div>
}
else if (_item != null && _inventory != null)
{
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <a href="/inventory/@InventoryId" class="text-muted text-decoration-none small">
                            <i class="bi bi-arrow-left me-1"></i> @_inventory.Title
                        </a>
                        <h1 class="h3 fw-bold mb-0 mt-1">@(_isNew ? "New Item" : "Edit Item")</h1>
                    </div>
                    <div class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 fw-semibold">
                        <i class="bi bi-tag-fill me-2"></i>@(_item.CustomId)
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show py-2">
                        <i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage
                        <button type="button" class="btn-close" @onclick='() => _errorMessage = ""'></button>
                    </div>
                }

                <EditForm Model="_item" OnValidSubmit="HandleSubmit">
                    <!-- Fixed Fields -->
                    <div class="row g-4 mb-5 p-4 bg-light rounded-4 border border-info border-opacity-10">
                        <div class="col-12 border-bottom pb-2 mb-2">
                            <span class="text-info fw-bold small text-uppercase">Fixed Information</span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Custom ID</label>
                            <input type="text" class="form-control rounded-pill shadow-none" @bind="_item.CustomId" />
                            <div class="form-text small">Unique ID within this inventory. Edit only if needed.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Created At</label>
                            <input type="text" class="form-control rounded-pill bg-white border-0 shadow-none text-muted" value="@_item.CreatedAt.ToString("g")" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Created By</label>
                            <input type="text" class="form-control rounded-pill bg-white border-0 shadow-none text-muted" value="@(_currentUser?.Name)" disabled />
                        </div>
                    </div>

                    <!-- Dynamic Custom Fields -->
                    @if (_inventory.FieldDefinitions.Any())
                    {
                        <div class="row g-4">
                            <div class="col-12 border-bottom pb-2 mb-2">
                                <span class="text-primary fw-bold small text-uppercase">Inventory Fields</span>
                            </div>
                            @foreach (var field in _inventory.FieldDefinitions.OrderBy(f => f.DisplayOrder))
                            {
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        @field.Title
                                        @if (!string.IsNullOrEmpty(field.Description))
                                        {
                                            <i class="bi bi-info-circle ms-1 text-muted small" title="@field.Description"></i>
                                        }
                                    </label>
                                    @if (field.Type == FieldType.String)
                                    {
                                        <input type="text" class="form-control rounded-pill shadow-none"
                                               @bind:get="GetStringValue(field.SlotIndex)"
                                               @bind:set="(v) => SetStringValue(field.SlotIndex, v)"
                                               placeholder="@field.Description" />
                                    }
                                    else if (field.Type == FieldType.Numeric)
                                    {
                                        <input type="number" class="form-control rounded-pill shadow-none"
                                               @bind:get="GetNumericValue(field.SlotIndex)"
                                               @bind:set="(v) => SetNumericValue(field.SlotIndex, v)"
                                               placeholder="@field.Description" />
                                    }
                                    else if (field.Type == FieldType.Boolean)
                                    {
                                        <div class="form-check form-switch mt-2">
                                            <input class="form-check-input" type="checkbox"
                                                   @bind:get="GetBoolValue(field.SlotIndex) ?? false"
                                                   @bind:set="(v) => SetBoolValue(field.SlotIndex, v)" />
                                            <label class="form-check-label text-muted small">@field.Description</label>
                                        </div>
                                    }
                                    else if (field.Type == FieldType.Multiline)
                                    {
                                        <textarea class="form-control rounded-4 shadow-none" rows="4"
                                                  @bind:get="GetTextValue(field.SlotIndex)"
                                                  @bind:set="(v) => SetTextValue(field.SlotIndex, v)"
                                                  placeholder="@field.Description"></textarea>
                                    }
                                    else if (field.Type == FieldType.Link)
                                    {
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0 rounded-start-pill ps-3">
                                                <i class="bi bi-link-45deg"></i>
                                            </span>
                                            <input type="text" class="form-control border-start-0 rounded-end-pill shadow-none"
                                                   @bind:get="GetLinkValue(field.SlotIndex)"
                                                   @bind:set="(v) => SetLinkValue(field.SlotIndex, v)"
                                                   placeholder="https://..." />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="d-flex gap-2 mt-5 justify-content-end">
                        <button type="button" class="btn btn-light rounded-pill px-4"
                                @onclick='() => Navigation.NavigateTo($"/inventory/{InventoryId}")'>Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Save Item
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid InventoryId { get; set; }
    [Parameter] public Guid ItemId { get; set; }

    private Inventory? _inventory;
    private Item? _item;
    private User? _currentUser;
    private bool _hasWriteAccess = false;
    private bool _isNew = true;
    private bool _loading = true;
    private bool _saving = false;
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await UserService.GetCurrentUserAsync();
        
        using var context = await DbFactory.CreateDbContextAsync();
        
        _inventory = await context.Inventories
            .AsNoTracking()
            .Include(i => i.FieldDefinitions.OrderBy(f => f.DisplayOrder))
            .FirstOrDefaultAsync(i => i.Id == InventoryId);

        if (_inventory != null && _currentUser != null)
        {
            var isOwnerOrAdmin = _currentUser.IsAdmin || _inventory.OwnerId == _currentUser.Id;
            _hasWriteAccess = isOwnerOrAdmin
                || _inventory.IsPublic
                || await context.InventoryAccesses
                    .AnyAsync(a => a.InventoryId == InventoryId && a.UserId == _currentUser.Id);
        }

        _isNew = ItemId == Guid.Empty;

        if (_isNew)
        {
            _item = new Item
            {
                Id = Guid.NewGuid(),
                InventoryId = InventoryId,
                CreatedById = _currentUser?.Id ?? Guid.Empty,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
            if (_inventory != null)
                _item.CustomId = await CustomIdService.GenerateIdAsync(_inventory);
        }
        else
        {
            _item = await context.Items.AsNoTracking().FirstOrDefaultAsync(i => i.Id == ItemId);
        }

        _loading = false;
    }

    private async Task HandleSubmit()
    {
        if (_item == null || _currentUser == null) return;
        _saving = true;
        _errorMessage = "";

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            
            _item.UpdatedAt = DateTime.UtcNow;

            if (_isNew)
            {
                _item.CreatedById = _currentUser.Id;
                context.Items.Add(_item);
            }
            else
            {
                context.Entry(_item).State = EntityState.Modified;
            }

            await context.SaveChangesAsync();
            Navigation.NavigateTo($"/inventory/{InventoryId}");
        }
        catch (DbUpdateException dbEx) when (
            dbEx.InnerException?.Message.Contains("duplicate key") == true ||
            dbEx.InnerException?.Message.Contains("IX_Items") == true)
        {
            _errorMessage = "Custom ID conflict: this ID is already used in this inventory. Please edit the Custom ID field.";
        }
        catch (DbUpdateConcurrencyException)
        {
            _errorMessage = "This item or its inventory was modified by another user. Please reload and try again.";
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error saving item");
            _errorMessage = $"An unexpected error occurred: {ex.InnerException?.Message ?? ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private string? GetStringValue(int i) => i switch { 0 => _item?.StringField0, 1 => _item?.StringField1, _ => _item?.StringField2 };
    private void SetStringValue(int i, string? v) { if (_item == null) return; if (i == 0) _item.StringField0 = v; else if (i == 1) _item.StringField1 = v; else _item.StringField2 = v; }

    private double? GetNumericValue(int i) => i switch { 0 => _item?.NumberField0, 1 => _item?.NumberField1, _ => _item?.NumberField2 };
    private void SetNumericValue(int i, double? v) { if (_item == null) return; if (i == 0) _item.NumberField0 = v; else if (i == 1) _item.NumberField1 = v; else _item.NumberField2 = v; }

    private bool? GetBoolValue(int i) => i switch { 0 => _item?.BoolField0, 1 => _item?.BoolField1, _ => _item?.BoolField2 };
    private void SetBoolValue(int i, bool v) { if (_item == null) return; if (i == 0) _item.BoolField0 = v; else if (i == 1) _item.BoolField1 = v; else _item.BoolField2 = v; }

    private string? GetTextValue(int i) => i switch { 0 => _item?.TextField0, 1 => _item?.TextField1, _ => _item?.TextField2 };
    private void SetTextValue(int i, string? v) { if (_item == null) return; if (i == 0) _item.TextField0 = v; else if (i == 1) _item.TextField1 = v; else _item.TextField2 = v; }

    private string? GetLinkValue(int i) => i switch { 0 => _item?.LinkField0, 1 => _item?.LinkField1, _ => _item?.LinkField2 };
    private void SetLinkValue(int i, string? v) { if (_item == null) return; if (i == 0) _item.LinkField0 = v; else if (i == 1) _item.LinkField1 = v; else _item.LinkField2 = v; }
}
