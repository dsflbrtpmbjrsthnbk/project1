@page "/profile/{UserId:guid}"
@using UserManagementApp.Models
@using UserManagementApp.Services
@using Microsoft.EntityFrameworkCore
@inject UserManagementApp.Data.ApplicationDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>User Profile - InventoryHub</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_user == null)
{
    <div class="alert alert-danger text-center py-5">
        <h4>User Not Found</h4>
        <p>The requested user profile does not exist.</p>
        <a href="/" class="btn btn-primary mt-3">Go Home</a>
    </div>
}
else
{
    <div class="row align-items-center mb-5">
        <div class="col-md-2 text-center text-md-start mb-3 mb-md-0">
            <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle shadow" style="width: 120px; height: 120px; font-size: 3rem;">
                @_user.Name.FirstOrDefault()
            </div>
        </div>
        <div class="col-md-10 text-center text-md-start">
            <h1 class="fw-bold mb-1">@_user.Name</h1>
            <p class="text-muted mb-2">@_user.Email</p>
            <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-3">
                <span class="badge bg-light text-dark border"><i class="bi bi-calendar3 me-2"></i>Joined @_user.RegistrationTime.ToString("MMMM d, yyyy")</span>
                @if (_user.IsAdmin)
                {
                    <span class="badge bg-primary"><i class="bi bi-shield-fill-check me-2"></i>Admin</span>
                }
            </div>
        </div>
    </div>

    <!-- Public Inventories Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold"><i class="bi bi-collection-fill me-2 text-primary"></i>Public Inventories</h5>
            <p class="small text-muted mb-0">Inventories created by @_user.Name</p>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Inventory Title</th>
                        <th>Category</th>
                        <th>Items</th>
                        <th class="pe-4">Last Updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in _publicInventories)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(inv.ImageUrl))
                                    {
                                        <img src="@inv.ImageUrl" class="rounded me-3" style="width:32px;height:32px;object-fit:cover;" alt="">
                                    }
                                    <a href="/inventory/@inv.Id" class="text-decoration-none fw-semibold text-dark">@inv.Title</a>
                                </div>
                            </td>
                            <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill">@inv.Category?.Name</span></td>
                            <td><span class="text-muted">@inv.Items.Count items</span></td>
                            <td class="pe-4 text-muted small">@inv.UpdatedAt.ToString("g")</td>
                        </tr>
                    }
                    @if (!_publicInventories.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">No public inventories found for this user.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public Guid UserId { get; set; }

    private User? _user;
    private List<Inventory> _publicInventories = new();
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _user = await DbContext.Users.FindAsync(UserId);
        
        if (_user != null)
        {
            _publicInventories = await DbContext.Inventories
                .Include(i => i.Category)
                .Include(i => i.Items)
                .Where(i => i.OwnerId == UserId && i.IsPublic)
                .OrderByDescending(i => i.UpdatedAt)
                .ToListAsync();
        }

        _loading = false;
    }
}
