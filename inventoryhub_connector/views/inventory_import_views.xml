<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventoryhub_inventory_list" model="ir.ui.view">
        <field name="name">inventoryhub.inventory.list</field>
        <field name="model">inventoryhub.inventory</field>
        <field name="arch" type="xml">
            <tree string="Imported Inventories" decoration-muted="not last_synced">
                <field name="name"/>
                <field name="category"/>
                <field name="owner"/>
                <field name="item_count"/>
                <field name="field_count"/>
                <field name="is_public" widget="boolean"/>
                <field name="last_synced"/>
                <button name="action_import"
                        type="object"
                        string="Refresh"
                        icon="fa-refresh"
                        class="btn-sm btn-secondary"/>
            </tree>
        </field>
    </record>

    <record id="view_inventoryhub_field_list_inline" model="ir.ui.view">
        <field name="name">inventoryhub.field.list.inline</field>
        <field name="model">inventoryhub.field</field>
        <field name="arch" type="xml">
            <tree string="Fields">
                <field name="name"/>
                <field name="field_type"/>
                <field name="stat_summary"/>
                <field name="stat_min" optional="show"/>
                <field name="stat_max" optional="show"/>
                <field name="stat_avg" optional="show"/>
                <field name="stat_top_values" optional="show"/>
                <field name="stat_non_null_count" optional="show"/>
                <field name="stat_true_count" optional="show"/>
                <field name="stat_false_count" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_inventoryhub_field_form" model="ir.ui.view">
        <field name="name">inventoryhub.field.form</field>
        <field name="model">inventoryhub.field</field>
        <field name="arch" type="xml">
            <form string="Field Details" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Field Info">
                            <field name="name"/>
                            <field name="field_type"/>
                            <field name="external_field_id"/>
                        </group>
                        <group string="Summary">
                            <field name="stat_summary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Numeric Stats" attrs="{'invisible': [('field_type', '!=', 'numeric')]}">
                            <group>
                                <field name="stat_min"/>
                                <field name="stat_max"/>
                                <field name="stat_avg"/>
                            </group>
                        </page>
                        <page string="Text Stats" attrs="{'invisible': [('field_type', 'not in', ['string', 'multiline'])]}">
                            <group>
                                <field name="stat_non_null_count"/>
                                <field name="stat_top_values"/>
                            </group>
                        </page>
                        <page string="Boolean Stats" attrs="{'invisible': [('field_type', '!=', 'boolean')]}">
                            <group>
                                <field name="stat_true_count"/>
                                <field name="stat_false_count"/>
                            </group>
                        </page>
                        <page string="Link Stats" attrs="{'invisible': [('field_type', '!=', 'link')]}">
                            <group>
                                <field name="stat_non_null_count"/>
                                <field name="stat_total_items"/>
                            </group>
                        </page>
                        <page string="Raw JSON">
                            <field name="stats_json" widget="char" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_inventoryhub_inventory_form" model="ir.ui.view">
        <field name="name">inventoryhub.inventory.form</field>
        <field name="model">inventoryhub.inventory</field>
        <field name="arch" type="xml">
            <form string="InventoryHub Import">
                <header>
                    <button name="action_import"
                            type="object"
                            string="Import / Refresh from InventoryHub"
                            class="btn-primary"
                            icon="fa-download"/>
                    <field name="last_synced" widget="datetime" readonly="1"
                           class="oe_read_only" nolabel="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" placeholder="(not yet imported)"/>
                        </h1>
                    </div>

                    <group string="Connection Settings" col="2">
                        <field name="api_url"
                               placeholder="https://project1-vkwm.onrender.com"/>
                        <field name="external_id"
                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
                        <field name="api_token" password="True"/>
                    </group>

                    <group string="Inventory Metadata" col="2">
                        <field name="category" readonly="1"/>
                        <field name="owner" readonly="1"/>
                        <field name="item_count" readonly="1"/>
                        <field name="field_count" readonly="1"/>
                        <field name="is_public" readonly="1" widget="boolean"/>
                        <field name="created_at" readonly="1" widget="datetime"/>
                        <field name="updated_at" readonly="1" widget="datetime"/>
                    </group>

                    <group string="Description">
                        <field name="description" readonly="1" nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Fields &amp; Statistics">
                            <field name="field_ids"
                                   widget="one2many"
                                   view_id="view_inventoryhub_field_list_inline"
                                   nolabel="1"
                                   readonly="1">
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_inventoryhub_inventory_search" model="ir.ui.view">
        <field name="name">inventoryhub.inventory.search</field>
        <field name="model">inventoryhub.inventory</field>
        <field name="arch" type="xml">
            <search string="Search Inventories">
                <field name="name"/>
                <field name="category"/>
                <field name="owner"/>
                <filter string="Public" name="filter_public" domain="[('is_public','=',True)]"/>
                <filter string="Synced" name="filter_synced" domain="[('last_synced','!=',False)]"/>
                <group string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Owner" name="group_owner" context="{'group_by': 'owner'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_inventoryhub_inventory" model="ir.actions.act_window">
        <field name="name">InventoryHub Inventories</field>
        <field name="res_model">inventoryhub.inventory</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_inventoryhub_inventory_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No inventories imported yet!
            </p>
            <p>
                Create a new record, fill in the <b>API URL</b>, <b>External ID</b>, and
                <b>API Token</b> from your InventoryHub application, then click
                <b>Import / Refresh from InventoryHub</b>.
            </p>
        </field>
    </record>

    <menuitem id="menu_inventoryhub_root"
              name="InventoryHub"
              sequence="90"
              web_icon="inventoryhub_connector,static/description/icon.png"/>

    <menuitem id="menu_inventoryhub_inventories"
              name="Inventories"
              parent="menu_inventoryhub_root"
              action="action_inventoryhub_inventory"
              sequence="10"/>

</odoo>
